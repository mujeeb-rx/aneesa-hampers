rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Admin check: matches the ADMIN_EMAIL used in admin.html ──
    function isAdmin() {
      return request.auth != null &&
             request.auth.token.email == "aneesahampers@gmail.com";
    }

    // ── Users ──
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null;
    }

    // ── Orders ──
    // Admin reads/writes ALL orders (real-time dashboard)
    // Logged-in users can create & read their own orders
    // Guests (unauthenticated) can CREATE orders (uid will be null in the doc)
    match /orders/{orderId} {
      allow read, write: if isAdmin();

      // Logged-in users — read their own orders
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.uid ||
         request.auth.uid == resource.data.customerUID);

      // Logged-in users — create an order for themselves
      allow create: if request.auth != null &&
        (request.auth.uid == request.resource.data.uid ||
         request.auth.uid == request.resource.data.customerUID);

      // GUEST orders — uid is null, allow creation without auth
      allow create: if request.resource.data.uid == null ||
                       request.resource.data.uid == "";

      // Users can update/delete their own orders
      allow update, delete: if request.auth != null &&
        (request.auth.uid == resource.data.uid ||
         request.auth.uid == resource.data.customerUID);
    }

    // ── Offers ──
    match /offers/{offerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Site settings ──
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Reviews ──
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null &&
        request.resource.data.keys().hasAll(['name', 'rating', 'text', 'productId', 'createdAt']) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() >= 2 &&
        request.resource.data.name.size() <= 100 &&
        request.resource.data.rating is number &&
        request.resource.data.rating >= 1 &&
        request.resource.data.rating <= 5 &&
        request.resource.data.text is string &&
        request.resource.data.text.size() >= 10 &&
        request.resource.data.text.size() <= 1000;
      allow update, delete: if isAdmin();
    }

    // ── siteSettings ──
    match /siteSettings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Products ──
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Categories ──
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Subcategories ──
    match /subcategories/{subId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Leads ──
    match /leads/{leadId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ── Email analytics ──
    match /email_analytics/{docId} {
      allow read, write: if isAdmin();
    }

    // ── Promo codes ──
    match /promoCodes/{codeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Banners ──
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

  }
}
