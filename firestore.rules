rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email == "phatanmujeebkhan64@gmail.com";
    }

    // Users — readable by owner, writable by auth + functions
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null;
    }

    // Orders — readable/writable by the order owner OR admin
    match /orders/{orderId} {
      // Admin can read/write ALL orders
      allow read, write: if isAdmin();
      // Users can read their own orders
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.uid ||
         request.auth.uid == resource.data.customerUID);
      // Users can create orders for themselves
      allow create: if request.auth != null &&
        (request.auth.uid == request.resource.data.uid ||
         request.auth.uid == request.resource.data.customerUID);
      // Users can update/delete only their own orders
      allow update, delete: if request.auth != null &&
        (request.auth.uid == resource.data.uid ||
         request.auth.uid == resource.data.customerUID);
    }

    // Offers — public read, admin-only write
    match /offers/{offerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Site settings — public read
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Reviews — anyone can read; authenticated users can create (with validation); admin can delete/update
    match /reviews/{reviewId} {
      allow read: if true;
      // Only authenticated users can create reviews with proper validation
      allow create: if request.auth != null &&
        request.resource.data.keys().hasAll(['name', 'rating', 'text', 'productId', 'createdAt']) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() >= 2 &&
        request.resource.data.name.size() <= 100 &&
        request.resource.data.rating is number &&
        request.resource.data.rating >= 1 &&
        request.resource.data.rating <= 5 &&
        request.resource.data.text is string &&
        request.resource.data.text.size() >= 10 &&
        request.resource.data.text.size() <= 1000;
      allow update, delete: if isAdmin();
    }

    // siteSettings (used as config doc)
    match /siteSettings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Products — public read, admin-only write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Categories — public read, admin-only write
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Subcategories — public read, admin-only write
    match /subcategories/{subId} {
      allow read: if true;
      allow write: if isAdmin();
    }

  }
}
